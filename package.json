{
  "name": "symphony-orchestrator",
  "version": "0.1.0",
  "description": "A TypeScript Symphony service implementation for multi-project repository orchestration.",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "yarn@3.4.1",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/build-dashboard.mjs",
    "check": "tsc -p tsconfig.json --noEmit",
    "dashboard:build": "node scripts/build-dashboard.mjs",
    "dev": "node scripts/build-dashboard.mjs && tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@json-render/core": "^0.13.0",
    "@json-render/react": "^0.13.0",
    "dotenv": "^17.2.3",
    "liquidjs": "^10.18.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "yaml": "^2.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.27.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
