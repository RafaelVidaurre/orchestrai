{
  "name": "orchestrai",
  "version": "0.1.0",
  "description": "A TypeScript OrchestrAI service for multi-project repository orchestration.",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "yarn@3.4.1",
  "files": [
    "dist/src/",
    "dist/tui.mjs",
    "dist/dashboard-client.browser.js"
  ],
  "workspaces": [
    "packages/*",
    "packages/providers/*"
  ],
  "bin": "dist/src/cli.js",
  "exports": {
    "./config": {
      "types": "./dist/src/config-entry.d.ts",
      "default": "./dist/src/config-entry.js"
    },
    "./plugin-sdk": {
      "types": "./dist/src/plugin-sdk.d.ts",
      "default": "./dist/src/plugin-sdk.js"
    }
  },
  "typesVersions": {
    "*": {
      "config": [
        "dist/src/config-entry.d.ts"
      ],
      "plugin-sdk": [
        "dist/src/plugin-sdk.d.ts"
      ]
    }
  },
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/build-dashboard.mjs && node scripts/build-tui.mjs",
    "check": "tsc -p tsconfig.json --noEmit",
    "coverage": "vitest run --coverage",
    "dashboard:build": "node scripts/build-dashboard.mjs",
    "dev": "node scripts/build-dashboard.mjs && tsx src/cli.ts",
    "prepack": "yarn build",
    "start": "node dist/src/cli.js",
    "tui": "node scripts/build-dashboard.mjs && node scripts/build-tui.mjs && node dist/tui.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tabs": "^1.1.13",
    "dotenv": "^17.2.3",
    "esbuild": "^0.27.4",
    "express": "^5.1.0",
    "ink": "^6.8.0",
    "liquidjs": "^10.18.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "yaml": "^2.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.4",
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
