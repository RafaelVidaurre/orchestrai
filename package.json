{
  "name": "orchestrai",
  "version": "0.1.0",
  "description": "A TypeScript OrchestrAI service for multi-project repository orchestration.",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "yarn@3.4.1",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/build-dashboard.mjs && node scripts/build-tui.mjs",
    "check": "tsc -p tsconfig.json --noEmit",
    "coverage": "vitest run --coverage",
    "dashboard:build": "node scripts/build-dashboard.mjs",
    "dev": "node scripts/build-dashboard.mjs && tsx src/cli.ts",
    "start": "node dist/cli.js",
    "tui": "node scripts/build-dashboard.mjs && node scripts/build-tui.mjs && node dist/tui.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tabs": "^1.1.13",
    "dotenv": "^17.2.3",
    "ink": "^6.8.0",
    "liquidjs": "^10.18.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "yaml": "^2.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^3.2.4",
    "esbuild": "^0.27.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
